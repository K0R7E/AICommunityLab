# Used by docker compose (repo root) for Next.js build args — copy to .env
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: same origin as users see in the browser (OAuth + auth callback)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# GNews API (consumed server-side by frontend app)
GNEWS_API_KEY=
# Optional: tune AI news breadth/pagination
# GNEWS_PAGE_SIZE=10
# GNEWS_MAX_PAGES=5
# GNEWS_MAX_ARTICLES=100
# GNEWS_LANG=en
