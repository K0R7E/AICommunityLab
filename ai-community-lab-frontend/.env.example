# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for deleteAccount — service_role key (keep secret, server-only, never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: canonical origin for OAuth, auth callbacks, robots.txt, and sitemap.xml
# (avoids trusting Host behind proxies). Set in production. Example: https://yourdomain.com
# NEXT_PUBLIC_SITE_URL=

# Optional: RFC 9116 security.txt metadata overrides
# SECURITY_TXT_CONTACT=mailto:security@yourdomain.com
# SECURITY_TXT_POLICY_URL=https://yourdomain.com/security-policy
# SECURITY_TXT_ACKNOWLEDGMENTS_URL=https://yourdomain.com/security/thanks
# SECURITY_TXT_HIRING_URL=https://yourdomain.com/careers
# SECURITY_TXT_LANGUAGES=en, hu

# GNews API (server-side only; do NOT use NEXT_PUBLIC_ prefix)
GNEWS_API_KEY=

# Optional AI news fetch tuning
# GNEWS_PAGE_SIZE=10
# GNEWS_MAX_PAGES=5
# GNEWS_MAX_ARTICLES=100
# GNEWS_LANG=en

# CSP rollout mode (default report-only). Set to false when ready to enforce.
# CSP_REPORT_ONLY=true
